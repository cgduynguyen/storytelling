# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_API_TIMEOUT=30000

# Feature Flags
EXPO_PUBLIC_ENABLE_AUDIO=true
EXPO_PUBLIC_ENABLE_INTERACTIVE=true
EXPO_PUBLIC_ENABLE_OFFLINE=true

# Polling Configuration
EXPO_PUBLIC_STORY_POLL_INTERVAL=2000
EXPO_PUBLIC_STORY_MAX_RETRIES=15

# Storage Limits
EXPO_PUBLIC_MAX_LIBRARY_SIZE=50
